```gitignore
# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual Environment
venv/
env/
.venv/

# Environment Variables
.env

# IDE
.vscode/
.idea/

# MacOS
.DS_Store

# Logs
*.log

# Pytest
.pytest_cache/

# Coverage
.coverage
htmlcov/

# Build Files
build/
dist/
*.egg-info/

# Uploaded Files
uploads/

# Streamlit
.streamlit/secrets.toml

# Jupyter
.ipynb_checkpoints/

# Misc
*.swp
*.swo
```
